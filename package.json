{
  "name": "OpenDiagram",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "better-auth": "1.6.22",
      "evlog": "^2.19.2",
      "lucide-react": "^1.21.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@tailwindcss/postcss": "^4.3.1",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:studio": "turbo run db:studio -F @OpenDiagram/db",
    "db:generate": "turbo run db:generate -F @OpenDiagram/db",
    "db:migrate": "turbo run db:migrate -F @OpenDiagram/db",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@OpenDiagram/env": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "dotenv": "catalog:",
    "framer-motion": "^12.42.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@OpenDiagram/config": "workspace:*",
    "@types/bun": "catalog:",
    "@typescript/native-preview": "latest",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.5"
}
